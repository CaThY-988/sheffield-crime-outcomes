########################################
# terraform.tfvars.example
#
# Copy to terraform.tfvars and update values.
# Do NOT commit terraform.tfvars.
########################################

# -------- MUST EDIT --------

aws_region = "aws_region"

# Your 12-digit AWS account ID (not access key)
aws_account_id = "XXXXXXXXXXXXX"

# Must be globally unique across AWS
s3_bucket_name = "your-unique-bucket-name"

# Your Databricks Unity Catalog master role ARN
databricks_uc_master_role_arn = "arn:aws:iam::XXXX:role/..."

# Must exist in your Databricks workspace
databricks_principal = "account users"

# -------- CHANGE IF NAME EXISTS --------

iam_role_name = "sheffield-crime-role"

databricks_storage_credential_name = "sheffield_crime_sc"

databricks_external_location_name = "sheffield_crime_el"

# -------- LEAVE AS-IS --------

bucket_prefix = "police/raw"
bootstrap_external_id = "0000"
databricks_external_id = ""
create_external_location = false